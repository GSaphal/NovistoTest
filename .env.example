# Copy to `.env` and fill in. Never commit real keys.

# --- LLM provider (OpenAI key will be provided to you) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=            # a fast, inexpensive default for a take-home
OPENAI_EMBED_MODEL=

# --- Vector store (matches docker-compose service name) ---
VECTORSTORE_URL=



