# Copy to `.env` and fill in. Never commit real keys.

# --- LLM provider (OpenAI key will be provided to you) ---
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# --- Vector store (matches docker-compose service name; use localhost when
#     running tests/scripts from the host instead of inside the compose network) ---
DATABASE_URL=postgresql://rag:rag@db:5432/rag

# --- Local data corpus (defaults to <repo-root>/data, override only if needed) ---
DATA_DIR=

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_SERVER_URL=http://mcp-server:8765/mcp